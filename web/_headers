/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://drip.datapurge.iamnottheproduct.com; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/embed.html
  ! X-Frame-Options
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://drip.datapurge.iamnottheproduct.com; font-src 'self'; frame-ancestors *; base-uri 'self'; form-action 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://drip.datapurge.iamnottheproduct.com; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Allow cross-origin loading for self-hosted embeds
/js/*
  Access-Control-Allow-Origin: *

/css/*
  Access-Control-Allow-Origin: *

/data/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300, must-revalidate

/icon.svg
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=604800

# PWA caching: the service worker itself must never be cached so updates
# roll out immediately; icons and manifest can be cached generously
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: public, max-age=86400

/icon-192.png
  Cache-Control: public, max-age=604800

/icon-512.png
  Cache-Control: public, max-age=604800

/icon-maskable-512.png
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800
