{
  "name": "datapurge-drip",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create datapurge-drip",
    "db:migrate": "wrangler d1 execute datapurge-drip --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute datapurge-drip --local --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3"
  }
}
